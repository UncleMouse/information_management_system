<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.geometry.Insets?>

<VBox xmlns="http://javafx.com/javafx" xmlns:fx="http://javafx.com/fxml"
      fx:controller="com.example.information_management_system.controller.LoginController"
      alignment="CENTER" spacing="0" styleClass="root">

    <StackPane styleClass="login-container">
        <VBox alignment="CENTER" spacing="24" styleClass="login-card">
            <padding><Insets top="40" right="50" bottom="40" left="50"/></padding>

            <Label text="校园信息管理系统" styleClass="app-title"/>

            <VBox spacing="4" alignment="CENTER">
                <Label text="欢迎回来" styleClass="welcome-text"/>
                <Label text="请登录您的账号以继续" styleClass="sub-text"/>
            </VBox>

            <VBox spacing="18" maxWidth="320">
                <VBox spacing="6">
                    <Label text="用户名" styleClass="field-label"/>
                    <TextField fx:id="usernameField" promptText="请输入学号或工号" styleClass="input-field"/>
                </VBox>

                <VBox spacing="6">
                    <Label text="密码" styleClass="field-label"/>
                    <PasswordField fx:id="passwordField" promptText="请输入密码" styleClass="input-field"/>
                </VBox>

                <Label fx:id="errorMessageLabel" styleClass="error-label" visible="false" wrapText="true"/>

                <Button fx:id="loginButton" text="登  录" styleClass="login-button" maxWidth="Infinity"/>
            </VBox>

            <VBox spacing="8" alignment="CENTER">
                <Hyperlink fx:id="toggleLoginLink" text="统一认证登录" styleClass="toggle-link"
                           onAction="#handleToggleLogin"/>
                <HBox spacing="16" alignment="CENTER">
                    <Hyperlink fx:id="studentQuickLogin" text="学生登录(测试)" styleClass="quick-link"
                               onAction="#studentQuickLogin"/>
                    <Hyperlink fx:id="teacherQuickLogin" text="教师登录(测试)" styleClass="quick-link"
                               onAction="#teacherQuickLogin"/>
                    <Hyperlink fx:id="adminQuickLogin" text="管理员登录(测试)" styleClass="quick-link"
                               onAction="#adminQuickLogin"/>
                </HBox>
            </VBox>
        </VBox>
    </StackPane>
</VBox>
