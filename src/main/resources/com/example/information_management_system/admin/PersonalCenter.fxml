<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.Separator?>
<?import javafx.scene.layout.ColumnConstraints?>
<?import javafx.scene.layout.GridPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.RowConstraints?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.text.Font?>

<VBox xmlns="http://javafx.com/javafx" xmlns:fx="http://javafx.com/fxml"
      fx:controller="com.example.information_management_system.controller.admin.PersonalCenterController"
      stylesheets="@../css/admin/personalCenter.css"
      styleClass="page-root" spacing="24">

    <padding><Insets top="28" right="48" bottom="28" left="48" /></padding>

    <!-- Header -->
    <HBox alignment="CENTER_LEFT" spacing="16">
        <Label text="个人中心" styleClass="page-title">
            <font><Font name="System Bold" size="22" /></font>
        </Label>
    </HBox>

    <!-- Action Buttons -->
    <HBox spacing="12">
        <Button fx:id="btnEditInfo" text="编辑资料" styleClass="btn-primary" />
        <Button fx:id="btnChangePassword" text="修改密码" styleClass="btn-outline" />
    </HBox>

    <!-- Info Card -->
    <VBox styleClass="info-card" spacing="0">
        <padding><Insets top="28" right="32" bottom="28" left="32" /></padding>

        <Label text="基本信息" styleClass="card-section-title">
            <font><Font name="System Bold" size="15" /></font>
        </Label>
        <Separator styleClass="card-separator" />

        <GridPane hgap="24" vgap="16" styleClass="info-grid">
            <padding><Insets top="16" /></padding>
            <columnConstraints>
                <ColumnConstraints percentWidth="50" />
                <ColumnConstraints percentWidth="50" />
            </columnConstraints>

            <!-- Column 1 -->
            <Label text="用户名" styleClass="info-label" GridPane.columnIndex="0" GridPane.rowIndex="0" />
            <Label fx:id="usernameLabel" text="--" styleClass="info-value"
                   GridPane.columnIndex="0" GridPane.rowIndex="1" />

            <Label text="工号/学号" styleClass="info-label" GridPane.columnIndex="0" GridPane.rowIndex="2" />
            <Label fx:id="sduidLabel" text="--" styleClass="info-value"
                   GridPane.columnIndex="0" GridPane.rowIndex="3" />

            <Label text="手机号码" styleClass="info-label" GridPane.columnIndex="0" GridPane.rowIndex="4" />
            <Label fx:id="phoneLabel" text="未设置" styleClass="info-value"
                   GridPane.columnIndex="0" GridPane.rowIndex="5" />

            <Label text="电子邮箱" styleClass="info-label" GridPane.columnIndex="0" GridPane.rowIndex="6" />
            <Label fx:id="emailLabel" text="未设置" styleClass="info-value"
                   GridPane.columnIndex="0" GridPane.rowIndex="7" />

            <Label text="身份" styleClass="info-label" GridPane.columnIndex="0" GridPane.rowIndex="8" />
            <Label fx:id="identityLabel" text="--" styleClass="info-value"
                   GridPane.columnIndex="0" GridPane.rowIndex="9" />

            <!-- Column 2 -->
            <Label text="性别" styleClass="info-label" GridPane.columnIndex="1" GridPane.rowIndex="0" />
            <Label fx:id="sexLabel" text="--" styleClass="info-value"
                   GridPane.columnIndex="1" GridPane.rowIndex="1" />

            <Label text="学院" styleClass="info-label" GridPane.columnIndex="1" GridPane.rowIndex="2" />
            <Label fx:id="collegeLabel" text="--" styleClass="info-value"
                   GridPane.columnIndex="1" GridPane.rowIndex="3" />

            <Label text="专业" styleClass="info-label" GridPane.columnIndex="1" GridPane.rowIndex="4" />
            <Label fx:id="majorLabel" text="--" styleClass="info-value"
                   GridPane.columnIndex="1" GridPane.rowIndex="5" />

            <Label text="民族" styleClass="info-label" GridPane.columnIndex="1" GridPane.rowIndex="6" />
            <Label fx:id="nationLabel" text="--" styleClass="info-value"
                   GridPane.columnIndex="1" GridPane.rowIndex="7" />

            <Label text="籍贯" styleClass="info-label" GridPane.columnIndex="1" GridPane.rowIndex="8" />
            <Label fx:id="ethnicLabel" text="--" styleClass="info-value"
                   GridPane.columnIndex="1" GridPane.rowIndex="9" />
        </GridPane>

        <Separator styleClass="card-separator">
            <VBox.margin><Insets top="12" bottom="12" /></VBox.margin>
        </Separator>

        <Label text="其他信息" styleClass="card-section-title">
            <font><Font name="System Bold" size="15" /></font>
        </Label>

        <GridPane hgap="24" vgap="16" styleClass="info-grid">
            <padding><Insets top="16" /></padding>
            <columnConstraints>
                <ColumnConstraints percentWidth="50" />
                <ColumnConstraints percentWidth="50" />
            </columnConstraints>

            <Label text="政治面貌" styleClass="info-label" GridPane.columnIndex="0" GridPane.rowIndex="0" />
            <Label fx:id="politicsStatusLabel" text="--" styleClass="info-value"
                   GridPane.columnIndex="0" GridPane.rowIndex="1" />

            <Label text="入学年份" styleClass="info-label" GridPane.columnIndex="1" GridPane.rowIndex="0" />
            <Label fx:id="admissionLabel" text="--" styleClass="info-value"
                   GridPane.columnIndex="1" GridPane.rowIndex="1" />

            <Label text="毕业年份" styleClass="info-label" GridPane.columnIndex="1" GridPane.rowIndex="2" />
            <Label fx:id="graduationLabel" text="--" styleClass="info-value"
                   GridPane.columnIndex="1" GridPane.rowIndex="3" />
        </GridPane>
    </VBox>

</VBox>
