<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.text.Font?>

<VBox xmlns="http://javafx.com/javafx" xmlns:fx="http://javafx.com/fxml"
      fx:controller="com.example.information_management_system.controller.admin.TermManagementController"
      stylesheets="@../css/admin/studentManagement.css"
      styleClass="page-root" spacing="16">

    <padding><Insets top="24" right="28" bottom="24" left="28"/></padding>

    <Label text="学期设置" styleClass="page-title">
        <font><Font name="System Bold" size="20"/></font>
    </Label>

    <HBox spacing="10" alignment="CENTER_LEFT">
        <Button fx:id="btnAddTerm" text="+ 添加学期" styleClass="btn-primary"/>
        <Button fx:id="btnEditTerm" text="编辑选中" styleClass="btn-outline" disable="true"/>
        <Button fx:id="btnDeleteTerm" text="删除选中" styleClass="btn-danger" disable="true"/>
        <Button fx:id="btnRefresh" text="刷新" styleClass="btn-secondary"/>
        <Region HBox.hgrow="ALWAYS"/>
        <Label fx:id="statusLabel" text="" styleClass="status-label"/>
    </HBox>

    <TableView fx:id="termTable" styleClass="data-table" VBox.vgrow="ALWAYS">
        <columns>
            <TableColumn fx:id="colTerm" text="学期" prefWidth="200"/>
            <TableColumn fx:id="colSelectionStatus" text="选课状态" prefWidth="120"/>
            <TableColumn fx:id="colCurrentStatus" text="当前标记" prefWidth="120"/>
            <TableColumn fx:id="colActions" text="操作" prefWidth="120"/>
        </columns>
    </TableView>
</VBox>
