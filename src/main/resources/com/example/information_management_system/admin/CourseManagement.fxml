<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.ComboBox?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.text.Font?>

<VBox xmlns="http://javafx.com/javafx" xmlns:fx="http://javafx.com/fxml"
      fx:controller="com.example.information_management_system.controller.admin.CourseManagementController"
      stylesheets="@../css/admin/courseManagement.css"
      styleClass="page-root" spacing="16">

    <padding><Insets top="24" right="28" bottom="24" left="28" /></padding>

    <Label text="课程管理" styleClass="page-title">
        <font><Font name="System Bold" size="20" /></font>
    </Label>

    <!-- Search and Filter Bar -->
    <HBox spacing="10" alignment="CENTER_LEFT">
        <TextField fx:id="searchField" promptText="搜索课程代码、名称..." styleClass="search-field"
                   HBox.hgrow="ALWAYS" />
        <Label text="学期:" styleClass="filter-label" />
        <ComboBox fx:id="semesterFilter" styleClass="filter-combo" prefWidth="130" />
        <Label text="状态:" styleClass="filter-label" />
        <ComboBox fx:id="statusFilter" styleClass="filter-combo" prefWidth="110" />
        <Button fx:id="btnSearch" text="搜索" styleClass="btn-primary" />
    </HBox>

    <!-- Action Buttons -->
    <HBox spacing="10" alignment="CENTER_LEFT">
        <Button fx:id="btnApprove" text="审核通过" styleClass="btn-approve" disable="true" />
        <Button fx:id="btnReject" text="审核拒绝" styleClass="btn-danger" disable="true" />
        <Button fx:id="btnRefresh" text="刷新" styleClass="btn-secondary" />
        <Region HBox.hgrow="ALWAYS" />
        <Label fx:id="statusLabel" text="" styleClass="status-label" />
    </HBox>

    <!-- Course Table -->
    <TableView fx:id="courseTable" styleClass="data-table" VBox.vgrow="ALWAYS">
        <columns>
            <TableColumn fx:id="colCode" text="课程代码" prefWidth="100" />
            <TableColumn fx:id="colName" text="课程名称" prefWidth="180" />
            <TableColumn fx:id="colTeacher" text="教师" prefWidth="100" />
            <TableColumn fx:id="colCredit" text="学分" prefWidth="60" />
            <TableColumn fx:id="colType" text="类型" prefWidth="80" />
            <TableColumn fx:id="colTerm" text="学期" prefWidth="100" />
            <TableColumn fx:id="colStatus" text="状态" prefWidth="80" />
        </columns>
        <columnResizePolicy>
            <TableView fx:constant="CONSTRAINED_RESIZE_POLICY"/>
        </columnResizePolicy>
    </TableView>
</VBox>
