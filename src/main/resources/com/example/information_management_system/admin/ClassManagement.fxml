<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.text.Font?>

<VBox xmlns="http://javafx.com/javafx" xmlns:fx="http://javafx.com/fxml"
      fx:controller="com.example.information_management_system.controller.admin.ClassManagementController"
      stylesheets="@../css/admin/classManagement.css"
      styleClass="page-root" spacing="16">

    <padding><Insets top="24" right="28" bottom="24" left="28" /></padding>

    <Label text="班级管理" styleClass="page-title">
        <font><Font name="System Bold" size="20" /></font>
    </Label>

    <HBox spacing="12" alignment="CENTER_LEFT">
        <TextField fx:id="searchField" promptText="搜索班级名称、专业、年级..." styleClass="search-field"
                   HBox.hgrow="ALWAYS" />
        <Button fx:id="btnSearch" text="搜索" styleClass="btn-primary" />
        <Region HBox.hgrow="ALWAYS" />
        <Button fx:id="btnAddClass" text="+ 添加班级" styleClass="btn-primary" />
    </HBox>

    <HBox spacing="10" alignment="CENTER_LEFT">
        <Button fx:id="btnEditClass" text="编辑选中" styleClass="btn-outline" disable="true" />
        <Button fx:id="btnDeleteClass" text="删除选中" styleClass="btn-danger" disable="true" />
        <Button fx:id="btnViewStudents" text="查看学生" styleClass="btn-outline" disable="true" />
        <Button fx:id="btnRefresh" text="刷新" styleClass="btn-secondary" />
        <Region HBox.hgrow="ALWAYS" />
        <Label fx:id="statusLabel" text="" styleClass="status-label" />
    </HBox>

    <TableView fx:id="classTable" styleClass="data-table" VBox.vgrow="ALWAYS">
        <columns>
            <TableColumn fx:id="colId" text="ID" prefWidth="50" />
            <TableColumn fx:id="colClassName" text="班级名称" prefWidth="200" />
            <TableColumn fx:id="colMajor" text="专业" prefWidth="180" />
            <TableColumn fx:id="colGrade" text="年级" prefWidth="100" />
            <TableColumn fx:id="colNumber" text="人数" prefWidth="80" />
        </columns>
        <columnResizePolicy>
            <TableView fx:constant="CONSTRAINED_RESIZE_POLICY"/>
        </columnResizePolicy>
    </TableView>
</VBox>
