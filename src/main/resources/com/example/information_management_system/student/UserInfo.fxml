<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.text.Font?>

<VBox xmlns="http://javafx.com/javafx" xmlns:fx="http://javafx.com/fxml"
      fx:controller="com.example.information_management_system.controller.student.UserInfoController"
      styleClass="page-root" stylesheets="@../css/student/UserInfo.css"
      spacing="16">

    <padding><Insets top="24" right="28" bottom="24" left="28"/></padding>

    <!-- Header -->
    <Label text="个人中心" styleClass="page-title" VBox.vgrow="NEVER">
        <font><Font name="System Bold" size="20"/></font>
    </Label>

    <ScrollPane fitToWidth="true" VBox.vgrow="ALWAYS" styleClass="scroll-pane">
        <VBox spacing="16.0" styleClass="content-container">
            <!-- Basic Info Card -->
            <VBox styleClass="info-card" VBox.vgrow="NEVER">
                <Label text="基本信息" styleClass="card-title"/>
                <GridPane hgap="20.0" vgap="14.0" styleClass="info-grid">
                    <padding><Insets top="16" right="20" bottom="16" left="20"/></padding>

                    <Label text="学号" styleClass="info-label" GridPane.columnIndex="0" GridPane.rowIndex="0"/>
                    <Label fx:id="sduidLabel" text="-" styleClass="info-value" GridPane.columnIndex="1" GridPane.rowIndex="0"/>

                    <Label text="姓名" styleClass="info-label" GridPane.columnIndex="0" GridPane.rowIndex="1"/>
                    <Label fx:id="nameLabel" text="-" styleClass="info-value" GridPane.columnIndex="1" GridPane.rowIndex="1"/>

                    <Label text="性别" styleClass="info-label" GridPane.columnIndex="2" GridPane.rowIndex="0"/>
                    <Label fx:id="genderLabel" text="-" styleClass="info-value" GridPane.columnIndex="3" GridPane.rowIndex="0"/>

                    <Label text="学院" styleClass="info-label" GridPane.columnIndex="2" GridPane.rowIndex="1"/>
                    <Label fx:id="collegeLabel" text="-" styleClass="info-value" GridPane.columnIndex="3" GridPane.rowIndex="1"/>

                    <Label text="专业" styleClass="info-label" GridPane.columnIndex="0" GridPane.rowIndex="2"/>
                    <Label fx:id="majorLabel" text="-" styleClass="info-value" GridPane.columnIndex="1" GridPane.rowIndex="2"/>

                    <Label text="班级" styleClass="info-label" GridPane.columnIndex="2" GridPane.rowIndex="2"/>
                    <Label fx:id="classNameLabel" text="-" styleClass="info-value" GridPane.columnIndex="3" GridPane.rowIndex="2"/>

                    <Label text="民族" styleClass="info-label" GridPane.columnIndex="0" GridPane.rowIndex="3"/>
                    <Label fx:id="nationLabel" text="-" styleClass="info-value" GridPane.columnIndex="1" GridPane.rowIndex="3"/>

                    <Label text="政治面貌" styleClass="info-label" GridPane.columnIndex="2" GridPane.rowIndex="3"/>
                    <Label fx:id="politicsLabel" text="-" styleClass="info-value" GridPane.columnIndex="3" GridPane.rowIndex="3"/>

                    <Label text="入学年份" styleClass="info-label" GridPane.columnIndex="0" GridPane.rowIndex="4"/>
                    <Label fx:id="admissionLabel" text="-" styleClass="info-value" GridPane.columnIndex="1" GridPane.rowIndex="4"/>

                    <Label text="毕业年份" styleClass="info-label" GridPane.columnIndex="2" GridPane.rowIndex="4"/>
                    <Label fx:id="graduationLabel" text="-" styleClass="info-value" GridPane.columnIndex="3" GridPane.rowIndex="4"/>
                </GridPane>
            </VBox>

            <!-- Contact Info Card -->
            <VBox styleClass="info-card" VBox.vgrow="NEVER">
                <Label text="联系方式" styleClass="card-title"/>
                <GridPane hgap="20.0" vgap="14.0" styleClass="info-grid">
                    <padding><Insets top="16" right="20" bottom="16" left="20"/></padding>

                    <Label text="手机号" styleClass="info-label" GridPane.columnIndex="0" GridPane.rowIndex="0"/>
                    <TextField fx:id="phoneField" promptText="请输入手机号" styleClass="input-field"
                               GridPane.columnIndex="1" GridPane.rowIndex="0"/>

                    <Label text="邮箱" styleClass="info-label" GridPane.columnIndex="0" GridPane.rowIndex="1"/>
                    <TextField fx:id="emailField" promptText="请输入邮箱" styleClass="input-field"
                               GridPane.columnIndex="1" GridPane.rowIndex="1"/>

                    <Button fx:id="saveContactBtn" text="保存联系方式" styleClass="save-btn"
                            GridPane.columnIndex="1" GridPane.rowIndex="2" GridPane.halignment="RIGHT"/>
                </GridPane>
            </VBox>

            <!-- Password Change Card -->
            <VBox styleClass="info-card" VBox.vgrow="NEVER">
                <Label text="修改密码" styleClass="card-title"/>
                <GridPane hgap="20.0" vgap="14.0" styleClass="info-grid">
                    <padding><Insets top="16" right="20" bottom="16" left="20"/></padding>

                    <Label text="旧密码" styleClass="info-label" GridPane.columnIndex="0" GridPane.rowIndex="0"/>
                    <PasswordField fx:id="oldPasswordField" promptText="请输入旧密码" styleClass="input-field"
                                   GridPane.columnIndex="1" GridPane.rowIndex="0"/>

                    <Label text="新密码" styleClass="info-label" GridPane.columnIndex="0" GridPane.rowIndex="1"/>
                    <PasswordField fx:id="newPasswordField" promptText="请输入新密码" styleClass="input-field"
                                   GridPane.columnIndex="1" GridPane.rowIndex="1"/>

                    <Label text="确认密码" styleClass="info-label" GridPane.columnIndex="0" GridPane.rowIndex="2"/>
                    <PasswordField fx:id="confirmPasswordField" promptText="请再次输入新密码" styleClass="input-field"
                                   GridPane.columnIndex="1" GridPane.rowIndex="2"/>

                    <Button fx:id="changePasswordBtn" text="修改密码" styleClass="save-btn"
                            GridPane.columnIndex="1" GridPane.rowIndex="3" GridPane.halignment="RIGHT"/>
                </GridPane>
            </VBox>
        </VBox>
    </ScrollPane>
</VBox>
