<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<VBox xmlns="http://javafx.com/javafx" xmlns:fx="http://javafx.com/fxml"
      fx:controller="com.example.information_management_system.controller.student.PasswordChangeController"
      styleClass="page-root" stylesheets="@../css/student/PasswordChange.css"
      spacing="16">

    <padding><Insets top="24" right="28" bottom="24" left="28"/></padding>

    <!-- Title -->
    <Label text="修改密码" styleClass="form-title" VBox.vgrow="NEVER"/>

    <!-- Form Content -->
    <VBox styleClass="form-card" VBox.vgrow="NEVER" spacing="16.0">
        <Label text="请输入您的旧密码和新密码" styleClass="form-subtitle"/>

        <VBox spacing="6.0">
            <Label text="旧密码" styleClass="field-label"/>
            <PasswordField fx:id="oldPasswordField" promptText="请输入旧密码" styleClass="input-field"/>
        </VBox>

        <VBox spacing="6.0">
            <Label text="新密码" styleClass="field-label"/>
            <PasswordField fx:id="newPasswordField" promptText="请输入新密码（至少6位）" styleClass="input-field"/>
        </VBox>

        <VBox spacing="6.0">
            <Label text="确认新密码" styleClass="field-label"/>
            <PasswordField fx:id="confirmPasswordField" promptText="请再次输入新密码" styleClass="input-field"/>
        </VBox>

        <HBox spacing="12.0" alignment="CENTER_RIGHT" styleClass="button-row">
            <Button fx:id="cancelBtn" text="取消" styleClass="cancel-btn"/>
            <Button fx:id="submitBtn" text="确认修改" styleClass="submit-btn"/>
        </HBox>
    </VBox>
</VBox>
