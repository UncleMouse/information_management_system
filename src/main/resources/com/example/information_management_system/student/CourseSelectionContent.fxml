<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.text.Font?>

<VBox xmlns="http://javafx.com/javafx" xmlns:fx="http://javafx.com/fxml"
      fx:controller="com.example.information_management_system.controller.student.CourseSelectionContentController"
      styleClass="page-root" stylesheets="@../css/student/CourseSelection.css"
      spacing="16">

    <padding><Insets top="24" right="28" bottom="24" left="28"/></padding>

    <!-- Header -->
    <HBox spacing="12" alignment="CENTER_LEFT">
        <Label text="选课中心" styleClass="page-title">
            <font><Font name="System Bold" size="20"/></font>
        </Label>
        <Region HBox.hgrow="ALWAYS"/>
        <Label text="学期：" styleClass="field-label"/>
        <ComboBox fx:id="termSelector" prefWidth="160" styleClass="form-combo"/>
        <TextField fx:id="searchField" promptText="搜索课程..." styleClass="search-field" prefWidth="220"/>
        <Button fx:id="searchBtn" text="搜索" styleClass="btn-primary"/>
    </HBox>

    <!-- TabPane for Available and Selected -->
    <TabPane styleClass="course-tab-pane" VBox.vgrow="ALWAYS" tabClosingPolicy="UNAVAILABLE">
        <Tab fx:id="availableTab" text="可选课程" closable="false">
            <TableView fx:id="availableTable" styleClass="data-table" VBox.vgrow="ALWAYS">
                <columns>
                    <TableColumn fx:id="availColName" text="课程名称" prefWidth="200"/>
                    <TableColumn fx:id="availColTeacher" text="教师" prefWidth="120"/>
                    <TableColumn fx:id="availColCredit" text="学分" prefWidth="70"/>
                    <TableColumn fx:id="availColType" text="类型" prefWidth="100"/>
                    <TableColumn fx:id="availColCapacity" text="容量" prefWidth="80"/>
                    <TableColumn fx:id="availColEnrolled" text="已选" prefWidth="70"/>
                    <TableColumn fx:id="availColTime" text="上课时间" prefWidth="180"/>
                    <TableColumn fx:id="availColAction" text="操作" prefWidth="80"/>
                </columns>
            <columnResizePolicy>
                <TableView fx:constant="CONSTRAINED_RESIZE_POLICY"/>
            </columnResizePolicy>
            </TableView>
        </Tab>
        <Tab fx:id="selectedTab" text="已选课程" closable="false">
            <TableView fx:id="selectedTable" styleClass="data-table" VBox.vgrow="ALWAYS">
                <columns>
                    <TableColumn fx:id="selColName" text="课程名称" prefWidth="250"/>
                    <TableColumn fx:id="selColTeacher" text="教师" prefWidth="120"/>
                    <TableColumn fx:id="selColCredit" text="学分" prefWidth="70"/>
                    <TableColumn fx:id="selColType" text="类型" prefWidth="100"/>
                    <TableColumn fx:id="selColTime" text="上课时间" prefWidth="250"/>
                    <TableColumn fx:id="selColAction" text="操作" prefWidth="80"/>
                </columns>
            <columnResizePolicy>
                <TableView fx:constant="CONSTRAINED_RESIZE_POLICY"/>
            </columnResizePolicy>
            </TableView>
        </Tab>
    </TabPane>
</VBox>
