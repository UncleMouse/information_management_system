<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.text.Font?>

<VBox xmlns="http://javafx.com/javafx/17" xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="com.example.information_management_system.controller.student.CourseSelectionContentController"
      styleClass="page-root" stylesheets="@../css/student/CourseSelection.css"
      VBox.vgrow="ALWAYS">

    <!-- Header -->
    <HBox styleClass="page-header" VBox.vgrow="NEVER" spacing="12.0" alignment="CENTER_LEFT">
        <Label text="选课中心" styleClass="page-title">
            <font><Font name="System Bold" size="20"/></font>
        </Label>
        <Region HBox.hgrow="ALWAYS"/>
        <Label text="学期：" styleClass="selector-label"/>
        <ComboBox fx:id="termSelector" prefWidth="160.0" styleClass="term-selector"/>
        <TextField fx:id="searchField" promptText="搜索课程..." prefWidth="220.0" styleClass="search-field"/>
        <Button fx:id="searchBtn" text="搜索" styleClass="search-btn"/>
    </HBox>

    <!-- TabPane for Available and Selected -->
    <TabPane styleClass="course-tab-pane" VBox.vgrow="NEVER" tabClosingPolicy="UNAVAILABLE">
        <Tab fx:id="availableTab" text="可选课程" closable="false">
            <VBox VBox.vgrow="ALWAYS">
                <TableView fx:id="availableTable" styleClass="data-table" VBox.vgrow="NEVER" prefHeight="350">
                    <columns>
                        <TableColumn fx:id="availColName" text="课程名称" prefWidth="150.0"/>
                        <TableColumn fx:id="availColTeacher" text="教师" prefWidth="80.0"/>
                        <TableColumn fx:id="availColCredit" text="学分" prefWidth="60.0"/>
                        <TableColumn fx:id="availColType" text="类型" prefWidth="80.0"/>
                        <TableColumn fx:id="availColCapacity" text="容量" prefWidth="60.0"/>
                        <TableColumn fx:id="availColEnrolled" text="已选人数" prefWidth="70.0"/>
                        <TableColumn fx:id="availColTime" text="上课时间" prefWidth="150.0"/>
                        <TableColumn fx:id="availColAction" text="操作" prefWidth="100.0"/>
                    </columns>
                </TableView>
            </VBox>
        </Tab>
        <Tab fx:id="selectedTab" text="已选课程" closable="false">
            <VBox VBox.vgrow="ALWAYS">
                <TableView fx:id="selectedTable" styleClass="data-table" VBox.vgrow="NEVER" prefHeight="180">
                    <columns>
                        <TableColumn fx:id="selColName" text="课程名称" prefWidth="180.0"/>
                        <TableColumn fx:id="selColTeacher" text="教师" prefWidth="90.0"/>
                        <TableColumn fx:id="selColCredit" text="学分" prefWidth="70.0"/>
                        <TableColumn fx:id="selColType" text="类型" prefWidth="90.0"/>
                        <TableColumn fx:id="selColTime" text="上课时间" prefWidth="220.0"/>
                        <TableColumn fx:id="selColAction" text="操作" prefWidth="100.0"/>
                    </columns>
                </TableView>
            </VBox>
        </Tab>
    </TabPane>
</VBox>
