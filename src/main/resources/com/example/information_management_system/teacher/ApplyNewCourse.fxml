<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.layout.*?>
<?import javafx.scene.control.*?>
<?import javafx.geometry.Insets?>
<?import javafx.scene.text.Font?>

<VBox xmlns="http://javafx.com/javafx"
      xmlns:fx="http://javafx.com/fxml"
      fx:controller="com.example.information_management_system.controller.teacher.ApplyNewCourseController"
      styleClass="page-root" spacing="16"
      stylesheets="@../css/teacher/ApplyNewCourse.css">

    <padding><Insets top="24" right="28" bottom="24" left="28"/></padding>

    <HBox alignment="CENTER_LEFT" spacing="16">
        <Button fx:id="backButton" text="← 返回" styleClass="btn-back"/>
        <Label text="申请新课" styleClass="page-title">
            <font><Font name="System Bold" size="20"/></font>
        </Label>
    </HBox>

    <ScrollPane styleClass="form-scroll" fitToWidth="true" VBox.vgrow="ALWAYS">
        <VBox styleClass="form-container" spacing="16">
            <padding><Insets top="20" right="24" bottom="20" left="24"/></padding>

            <GridPane hgap="16" vgap="14">
                <columnConstraints>
                    <ColumnConstraints percentWidth="50"/>
                    <ColumnConstraints percentWidth="50"/>
                </columnConstraints>

                <VBox spacing="6" GridPane.columnIndex="0" GridPane.rowIndex="0">
                    <Label text="课程名称 *" styleClass="field-label"/>
                    <TextField fx:id="courseNameField" promptText="请输入课程名称" styleClass="form-field"/>
                </VBox>

                <VBox spacing="6" GridPane.columnIndex="1" GridPane.rowIndex="0">
                    <Label text="课程分类 *" styleClass="field-label"/>
                    <ComboBox fx:id="categoryComboBox" promptText="请选择分类" styleClass="form-combo"/>
                </VBox>

                <VBox spacing="6" GridPane.columnIndex="0" GridPane.rowIndex="1">
                    <Label text="学分 *" styleClass="field-label"/>
                    <TextField fx:id="creditField" promptText="请输入学分" styleClass="form-field"/>
                </VBox>

                <VBox spacing="6" GridPane.columnIndex="1" GridPane.rowIndex="1">
                    <Label text="学期 *" styleClass="field-label"/>
                    <ComboBox fx:id="termComboBox" promptText="请选择学期" styleClass="form-combo"/>
                </VBox>

                <VBox spacing="6" GridPane.columnIndex="0" GridPane.rowIndex="2">
                    <Label text="容量 *" styleClass="field-label"/>
                    <TextField fx:id="capacityField" promptText="请输入课程容量" styleClass="form-field"/>
                </VBox>

                <VBox spacing="6" GridPane.columnIndex="0" GridPane.rowIndex="3">
                    <Label text="起始周 *" styleClass="field-label"/>
                    <TextField fx:id="weekStartField" promptText="例如: 1" styleClass="form-field"/>
                </VBox>

                <VBox spacing="6" GridPane.columnIndex="1" GridPane.rowIndex="3">
                    <Label text="结束周 *" styleClass="field-label"/>
                    <TextField fx:id="weekEndField" promptText="例如: 16" styleClass="form-field"/>
                </VBox>

                <VBox spacing="6" GridPane.columnIndex="0" GridPane.rowIndex="4">
                    <Label text="考试方式 *" styleClass="field-label"/>
                    <ComboBox fx:id="examinationComboBox" promptText="请选择考试方式" styleClass="form-combo"/>
                </VBox>

                <VBox spacing="6" GridPane.columnIndex="0" GridPane.rowIndex="5">
                    <Label text="平时成绩比例(%) *" styleClass="field-label"/>
                    <TextField fx:id="regularRatioField" promptText="例如: 30" styleClass="form-field"/>
                </VBox>

                <VBox spacing="6" GridPane.columnIndex="1" GridPane.rowIndex="5">
                    <Label text="期末成绩比例(%) *" styleClass="field-label"/>
                    <TextField fx:id="finalRatioField" promptText="例如: 70" styleClass="form-field"/>
                </VBox>

                <VBox spacing="6" GridPane.columnIndex="0" GridPane.rowIndex="6">
                    <Label text="开课学院" styleClass="field-label"/>
                    <TextField fx:id="collegeField" promptText="例如: 软件学院" styleClass="form-field"/>
                </VBox>

                <VBox spacing="6" GridPane.columnIndex="1" GridPane.rowIndex="6">
                    <Label text="课序号" styleClass="field-label"/>
                    <TextField fx:id="classNumField" promptText="例如: 001" styleClass="form-field"/>
                </VBox>
            </GridPane>

            <VBox spacing="6">
                <Label text="课程简介" styleClass="field-label"/>
                <TextArea fx:id="introTextArea" promptText="请输入课程简介..." styleClass="form-textarea"
                          prefRowCount="4" wrapText="true"/>
            </VBox>

            <HBox spacing="12" alignment="CENTER_RIGHT">
                <Button fx:id="cancelButton" text="取消" styleClass="btn-outline"/>
                <Button fx:id="submitButton" text="提交申请" styleClass="btn-primary"/>
            </HBox>
        </VBox>
    </ScrollPane>
</VBox>
