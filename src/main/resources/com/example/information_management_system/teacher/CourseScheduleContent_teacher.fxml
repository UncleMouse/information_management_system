<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.layout.*?>
<?import javafx.scene.control.*?>
<?import javafx.geometry.Insets?>
<?import javafx.scene.text.Font?>

<VBox xmlns="http://javafx.com/javafx"
      xmlns:fx="http://javafx.com/fxml"
      fx:controller="com.example.information_management_system.controller.teacher.CourseScheduleManagementContent"
      styleClass="page-root" spacing="16"
      stylesheets="@../css/teacher/TeacherCourseSchedule.css">

    <padding><Insets top="24" right="28" bottom="24" left="28"/></padding>

    <Label text="课表查询" styleClass="page-title">
        <font><Font name="System Bold" size="20"/></font>
    </Label>

    <HBox spacing="12" alignment="CENTER_LEFT">
        <Label text="学期：" styleClass="field-label"/>
        <ComboBox fx:id="termSelector" prefWidth="160" styleClass="form-combo"/>
        <Region HBox.hgrow="ALWAYS"/>
        <Button fx:id="btnPrevWeek" text="◀ 上一周" styleClass="btn-outline"/>
        <Label fx:id="weekLabel" text="第 1 周" styleClass="week-label"/>
        <Button fx:id="btnNextWeek" text="下一周 ▶" styleClass="btn-outline"/>
    </HBox>

    <TableView fx:id="scheduleTable" styleClass="schedule-table" VBox.vgrow="ALWAYS">
        <columns>
            <TableColumn fx:id="timeColumn" text="时间" prefWidth="100" resizable="false" sortable="false"/>
            <TableColumn fx:id="mondayColumn" text="周一" minWidth="80"/>
            <TableColumn fx:id="tuesdayColumn" text="周二" minWidth="80"/>
            <TableColumn fx:id="wednesdayColumn" text="周三" minWidth="80"/>
            <TableColumn fx:id="thursdayColumn" text="周四" minWidth="80"/>
            <TableColumn fx:id="fridayColumn" text="周五" minWidth="80"/>
            <TableColumn fx:id="saturdayColumn" text="周六" minWidth="80"/>
            <TableColumn fx:id="sundayColumn" text="周日" minWidth="80"/>
        </columns>
        <columnResizePolicy>
            <TableView fx:constant="CONSTRAINED_RESIZE_POLICY"/>
        </columnResizePolicy>
    </TableView>
</VBox>
