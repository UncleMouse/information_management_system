<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.layout.*?>
<?import javafx.scene.control.*?>
<?import javafx.geometry.Insets?>
<?import javafx.scene.text.Font?>

<VBox xmlns="http://javafx.com/javafx"
      xmlns:fx="http://javafx.com/fxml"
      fx:controller="com.example.information_management_system.controller.teacher.StudentListViewController"
      styleClass="page-root" spacing="16"
      stylesheets="@../css/teacher/StudentListView.css">

    <padding><Insets top="24" right="28" bottom="24" left="28"/></padding>

    <HBox alignment="CENTER_LEFT" spacing="16">
        <Button fx:id="backButton" text="← 返回" styleClass="btn-back"/>
        <Label fx:id="courseNameLabel" text="学生名单" styleClass="page-title">
            <font><Font name="System Bold" size="20"/></font>
        </Label>
        <Region HBox.hgrow="ALWAYS"/>
        <Label fx:id="studentCountLabel" text="共 0 名学生" styleClass="count-label"/>
    </HBox>

    <HBox spacing="12" alignment="CENTER_LEFT">
        <TextField fx:id="searchField" promptText="搜索学生姓名、学号或班级..." styleClass="search-field"
                   prefWidth="350"/>
    </HBox>

    <TableView fx:id="studentTable" styleClass="data-table" VBox.vgrow="NEVER" prefHeight="400">
        <columns>
            <TableColumn fx:id="sduidColumn" text="学号" prefWidth="130"/>
            <TableColumn fx:id="nameColumn" text="姓名" prefWidth="100"/>
            <TableColumn fx:id="genderColumn" text="性别" prefWidth="60"/>
            <TableColumn fx:id="departmentColumn" text="院系" prefWidth="120"/>
            <TableColumn fx:id="majorColumn" text="专业" prefWidth="120"/>
            <TableColumn fx:id="gradeColumn" text="年级" prefWidth="80"/>
            <TableColumn fx:id="classNameColumn" text="班级" prefWidth="120"/>
            <TableColumn fx:id="statusColumn" text="状态" prefWidth="80"/>
        </columns>
        <columnResizePolicy>
            <TableView fx:constant="CONSTRAINED_RESIZE_POLICY"/>
        </columnResizePolicy>
    </TableView>
</VBox>
