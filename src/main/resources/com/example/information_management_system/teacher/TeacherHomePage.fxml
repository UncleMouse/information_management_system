<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.layout.*?>
<?import javafx.scene.control.*?>
<?import javafx.geometry.Insets?>
<?import javafx.scene.text.Font?>

<VBox xmlns="http://javafx.com/javafx"
      xmlns:fx="http://javafx.com/fxml"
      fx:controller="com.example.information_management_system.controller.teacher.TeacherHomePageController"
      styleClass="page-root" spacing="20"
      stylesheets="@../css/teacher/TeacherHomePage.css">

    <padding><Insets top="24" right="28" bottom="24" left="28"/></padding>

    <HBox alignment="CENTER_LEFT">
        <VBox spacing="4">
            <Label fx:id="welcomeLabel" text="欢迎回来" styleClass="welcome-text"/>
            <Label text="以下是您的教学概览" styleClass="subtitle-text"/>
        </VBox>
    </HBox>

    <HBox spacing="16" styleClass="stats-row">
        <VBox styleClass="stat-card" HBox.hgrow="ALWAYS" alignment="CENTER" spacing="8">
            <padding><Insets top="20" right="16" bottom="20" left="16"/></padding>
            <Label text="我的课程" styleClass="stat-label"/>
            <Label fx:id="courseCountLabel" text="-" styleClass="stat-value"/>
            <Label text="本学期" styleClass="stat-sub"/>
        </VBox>
        <VBox styleClass="stat-card" HBox.hgrow="ALWAYS" alignment="CENTER" spacing="8">
            <padding><Insets top="20" right="16" bottom="20" left="16"/></padding>
            <Label text="学生总数" styleClass="stat-label"/>
            <Label fx:id="studentCountLabel" text="-" styleClass="stat-value"/>
            <Label text="累计" styleClass="stat-sub"/>
        </VBox>
        <VBox styleClass="stat-card" HBox.hgrow="ALWAYS" alignment="CENTER" spacing="8">
            <padding><Insets top="20" right="16" bottom="20" left="16"/></padding>
            <Label text="待录入成绩" styleClass="stat-label"/>
            <Label fx:id="pendingScoreLabel" text="-" styleClass="stat-value"/>
            <Label text="未完成" styleClass="stat-sub"/>
        </VBox>
        <VBox styleClass="stat-card" HBox.hgrow="ALWAYS" alignment="CENTER" spacing="8">
            <padding><Insets top="20" right="16" bottom="20" left="16"/></padding>
            <Label text="当前学期" styleClass="stat-label"/>
            <Label fx:id="currentTermLabel" text="-" styleClass="stat-value"/>
            <Label text="学期信息" styleClass="stat-sub"/>
        </VBox>
    </HBox>

    <HBox VBox.vgrow="ALWAYS" spacing="16">
        <VBox styleClass="card" HBox.hgrow="ALWAYS" VBox.vgrow="ALWAYS">
            <HBox styleClass="card-header">
                <Label text="我的课程" styleClass="card-title"/>
            </HBox>
            <VBox fx:id="recentCoursesBox" styleClass="card-body" VBox.vgrow="ALWAYS" spacing="8">
                <Label text="  加载中..." styleClass="loading-text"/>
            </VBox>
        </VBox>

        <VBox spacing="16" prefWidth="280" VBox.vgrow="ALWAYS">
            <VBox styleClass="card">
                <HBox styleClass="card-header">
                    <Label text="快捷操作" styleClass="card-title"/>
                </HBox>
                <VBox styleClass="card-body" spacing="10">
                    <Button text="开始录入成绩" styleClass="btn-primary" maxWidth="Infinity" onAction="#handleInputScore"/>
                    <Button text="申请新课" styleClass="btn-outline" maxWidth="Infinity" onAction="#handleApplyNewCourse"/>
                    <Button text="查看课表" styleClass="btn-outline" maxWidth="Infinity" onAction="#handleViewSchedule"/>
                </VBox>
            </VBox>

            <VBox styleClass="card" VBox.vgrow="ALWAYS">
                <HBox styleClass="card-header">
                    <Label text="最新公告" styleClass="card-title"/>
                </HBox>
                <VBox fx:id="noticesBox" styleClass="card-body" VBox.vgrow="ALWAYS" spacing="6">
                    <Label text="  加载中..." styleClass="loading-text"/>
                </VBox>
            </VBox>
        </VBox>
    </HBox>
</VBox>
